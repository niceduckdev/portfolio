---
import Column from "@components/modular/column.astro";
import Text from "@components/modular/text.astro";
import Navigation from "@components/navigation.astro";
import Profile from "@components/profile.astro";
import {getHighlightedProject} from "@services/projects.ts";
import Card from "@components/modular/card.astro";
import Quote from "@components/modular/quote.astro";
import Link from "@components/modular/link.astro";
import Page from "@layouts/page.astro";

const project = await getHighlightedProject();
---

<Page>
    <Navigation/>

    <Column>
        <Column>
            <Profile/>

            <Column>
                <Text>
                    Hi there! I'm Kaj, a software developer based in Antwerp.
                </Text>
                <Text>
                    I recently graduated with a <b>bachelor's degree in Applied
                    Computer Science</b> from KdG University of Applied Sciences in
                    Antwerp.
                </Text>

                <Quote>
                    You should probably read{" "}
                    <Link href="/articles/about-me"
                    >this article
                    </Link
                    >
                    {" "}
                    to learn more about me!
                </Quote>
            </Column>

            <Column>
                <Text>
                    Check out "{project.data.title}", one of my favourite
                    projects!
                </Text>
                <Card
                        title={project.data.title}
                        date={project.data.date}
                        description={project.data.description}
                        tags={project.data.tags}

                        href={`/projects/${project.id}`}
                        image={`${project.id}/${project.data.image}`}
                />
            </Column>
        </Column>
    </Column>
</Page>
