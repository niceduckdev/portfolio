---
const {src, fill = true, hover = false} = Astro.props;

const path: string = `/images/${src}`;

const outer = "relative rounded-md border-2 w-full min-h-36 overflow-hidden";
const inner =
    "absolute inset-0 w-full h-full object-cover " +
    "transform-gpu transition-transform duration-300 ease-out";
const zoom = "group-hover:scale-[1.05]";
---

{
    fill ? (
    <section class={outer}>
        <img
                src={path}
                alt={src}
                class={`${inner} ${hover ? zoom : ""} border-none`}
        />
    </section>
        ) : (
    <img src={path} alt={src} class="rounded-md border-2 w-full"/>
        )
    }