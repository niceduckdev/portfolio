---
import Column from "@modular/column.astro";
import Row from "@modular/row.astro";
import Link from "@modular/link.astro";
import Linkedin from "@modular/icons/linkedin.astro";
import Mail from "@modular/icons/mail.astro";
import Github from "@modular/icons/github.astro";
import { Align } from "@lib/align.ts";
---

<section class="flex flex-col xs:flex-row xs:items-center gap-4 relative z-0">
    <img
        src="/images/kaj.png"
        alt="A picture of Kaj"
        class="rounded-md border-2 max-w-32 size-32"
    />

    <Column>
        <Link href="https://linkedin.com/in/kaj-botty">
            <Row align={Align.CENTER}>
                <Linkedin />
                LinkedIn
            </Row>
        </Link>
        <Link href="mailto:contact@niceduck.dev">
            <Row align={Align.CENTER}>
                <Mail />
                Email
            </Row>
        </Link>
        <Link href="https://github.com/niceduckdev">
            <Row align={Align.CENTER}>
                <Github />
                Github
            </Row>
        </Link>
    </Column>
</section>
