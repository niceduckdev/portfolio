---
import "@styles/global.css";

interface Props {
    title?: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
        <title>{title ?? "Kaj Botty - Software Developer"}</title>

        <link rel="sitemap" href="/sitemap-index.xml" />

        <meta
            property="og:title"
            content={title ?? "Kaj Botty - Software Developer"}
        />
        <meta
            property="og:description"
            content="Hi there! I'm Kaj, a software developer based in Antwerp."
        />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://niceduck.dev" />
        <meta
            property="og:image"
            content="https://niceduck.dev/images/quack.webp"
        />
    </head>
    <body
        class="font-sans dark:bg-dark dark:text-mid bg-dark-l text-mid-l font-bold cursor-default"
    >
        <slot />
    </body>
</html>
