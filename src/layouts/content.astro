---
import Column from "@modular/column.astro";
import "@styles/global.css";
import Base from "@layouts/base.astro";
import type { Article } from "@models/article";
import type { Project } from "@models/project";
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import Link from "@components/modular/link.astro";
import Row from "@components/modular/row.astro";
import ArrowLeft from "@components/modular/icons/arrow-left.astro";
import { Align } from "@lib/align";
import Stack from "@components/modular/stack.astro";
import Title from "@components/modular/title.astro";
import { formatDate } from "@lib/date";
import { getReadTime } from "@services/content";
import { getGap } from "@lib/gap";
import type { MarkdownHeading } from "astro";
import OnThisPage from "@components/on-this-page.astro";

interface Props {
    content: Article | Project;
    file: AstroComponentFactory;
    headings: MarkdownHeading[];
}

const { content, file: File, headings } = Astro.props;
const isProject = "team" in content;
---

<Base>
    <nav
        class="py-2 sticky top-0 z-50 bg-light/90 dark:bg-dark/90 backdrop-blur-2xl"
    >
        <Column align={Align.START}>
            <Link href={isProject ? "/projects" : "/articles"}>
                <Row align={Align.CENTER}>
                    <ArrowLeft />
                    {isProject ? "Projects" : "Articles"}
                </Row>
            </Link>
        </Column>
    </nav>

    <Column>
        <Stack>
            <Title>{content.title}</Title>
            <Row>
                <p>{formatDate(content.date)}</p>
                •
                <p>{getReadTime(content.content.body!)} min read</p>
            </Row>

            <slot name="team" />
        </Stack>

        <section id="content" class={`flex flex-col ${getGap(2)}`}>
            <File />
        </section>
    </Column>

    <OnThisPage headings={headings.filter((heading) => heading.depth === 1)} />
</Base>
